PORT=4000
URL_DB=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
PAYMENT_MODE=PHONEPE

# PhonePe Payment Gateway
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
# LIVE: PHONEPE_ENV=PRODUCTION and use live Client ID / Secret from PhonePe dashboard
# Public HTTPS URL (ngrok in dev): ngrok http 4000 → use forwarding URL here
PHONEPE_CALLBACK_BASE_URL=https://your-subdomain.ngrok-free.dev
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=
APP_SCHEME=courtkutchery
